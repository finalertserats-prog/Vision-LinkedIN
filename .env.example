# ===========================================================================
# Project VISION — environment variable template (BRD Appendix A).
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# MUST NEVER be committed (it carries the HMAC + token-encryption keys and the
# LinkedIn client secret). Every variable below maps 1:1 onto a field on the
# `Settings` class in src/vision/config.py.
# ===========================================================================

# --- Core ------------------------------------------------------------------
# Runtime mode. Controls fail-safe behaviour: dry_run = no email/no post,
# staging = email self + post-then-delete test, live = real publish (FR-20).
VISION_ENV=dry_run
# IANA timezone used for all local scheduling (publish slot, approval cutoff).
TZ=Asia/Kolkata
# SQLAlchemy URL. SQLite in dev (default), PostgreSQL in prod (BRD §22 / D5).
DATABASE_URL=sqlite:///vision.db
# Server secret used to HMAC-sign single-use approval links (§14.2). REQUIRED.
SECRET_HMAC_KEY=change-me-to-a-long-random-string
# Symmetric key used to encrypt OAuth tokens at rest (§11.6). REQUIRED.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENC_KEY=change-me-to-a-fernet-key

# --- LinkedIn --------------------------------------------------------------
# Developer-app credentials for the official Posts API (§6/§15).
LI_CLIENT_ID=your-linkedin-client-id
LI_CLIENT_SECRET=your-linkedin-client-secret
# OAuth redirect registered on the LinkedIn app (§15.1).
LI_REDIRECT_URI=https://your-vps-domain/oauth/linkedin/callback
# Required `LinkedIn-Version` header value, format YYYYMM (§6).
LI_VERSION=202506
# Publishing method: `api` (official) or `prefill` (degraded manual fallback, §15.5).
PUBLISH_MODE=api
# Local time-of-day to publish approved drafts (§10.3 / D7).
PUBLISH_SLOT_LOCAL=09:00
# Local time-of-day after which un-actioned drafts expire — no post (FR-16).
APPROVE_CUTOFF_LOCAL=20:00

# --- Email -----------------------------------------------------------------
# Transactional provider for the daily approval email (D4). Deliverability of
# the Approve links is critical, so a real transactional provider is preferred.
EMAIL_PROVIDER=resend
# From/To addresses for the approval + confirmation emails (§14.1).
EMAIL_FROM=vision@your-domain
EMAIL_TO=your-finalert-inbox@example.com
# Provider-specific API key (Resend/Postmark/SES). Leave blank for smtp mode.
EMAIL_API_KEY=your-email-provider-api-key

# --- Brahmastra / models ---------------------------------------------------
# Invocation mode. This build uses CLI-only (local council scripts); no API keys.
BRAHMASTRA_MODE=cli
# Directory holding the council CLI scripts (gemini_call.sh, codex_call.sh, etc.).
# Defaults to ~/.claude/council when unset.
BRAHMASTRA_COUNCIL_DIR=~/.claude/council
# Lane names routed onto the CLI scripts for the generate/critique/verify passes
# (§13.1). Distinct lanes give genuine multi-model cross-checking.
MODEL_GENERATE=gemini
MODEL_CRITIQUE=codex
MODEL_VERIFY=claude

# --- Content ---------------------------------------------------------------
# Recency window for ingested items, in hours (§12.1).
RECENCY_HOURS=48
# Minimum claim-grounding percentage required for auto-eligibility (§13.5).
GROUNDING_MIN_PCT=100
# Cosine-similarity threshold above which a draft counts as a duplicate (§12.4).
DEDUP_SIM_THRESHOLD=0.80

# --- Images / visuals (§13.6) ----------------------------------------------
# Master switch for the visual lane.
IMAGE_ENABLED=true
# Diffusion model id for concept illustrations (confirm exact id at build time).
IMAGE_MODEL=gemini-image
# Per-week cap so image cadence stays natural (§13.6 guardrails).
IMAGE_MAX_PER_WEEK=4
# Fixed style guide for concept illustrations (no text, no logos).
IMAGE_STYLE_GUIDE=minimal, professional, muted palette, no text, no logos
# BRAHMASTRA brand palette for deterministically rendered cards.
CARD_BRAND_PALETTE=navy=#0B1F3A;gold=#C9A24B

# --- Author / signature (§15.6, D9) ----------------------------------------
# How the Brahmastra signature appears: off | card_watermark | text_footer | both.
POST_SIGNATURE_MODE=card_watermark
# Text appended to the post body when signature mode includes text_footer.
POST_SIGNATURE_TEXT=— curated via Brahmastra, my multi-AI system
# Path to the BRAHMASTRA logo used for card watermarks.
BRAHMASTRA_LOGO_PATH=/opt/vision/assets/brahmastra_logo.svg
