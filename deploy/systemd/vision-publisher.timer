[Unit]
Description=Fire VISION publisher every 5 minutes (BRD §10.2/§10.3)

[Timer]
# Every 5 minutes on the wall-clock (00,05,10,...). Timezone-agnostic — a 5-min
# poll doesn't care about IST vs UTC. Persistent is intentionally OFF: a missed
# tick is irrelevant, the next one (≤5 min later) does the same work.
OnCalendar=*:0/5
# Small jitter avoids every timer firing at the exact same instant after boot.
RandomizedDelaySec=30
Unit=vision-publisher.service

[Install]
WantedBy=timers.target
